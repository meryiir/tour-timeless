# Copy to ".env" and fill in. Restart `npm run dev` after changes.
# Create an OAuth 2.0 Client ID (Web application) in Google Cloud Console:
# APIs & Services → Credentials → Create Credentials → OAuth client ID
# Authorized JavaScript origins: http://localhost:5173
# Authorized redirect URIs: not required for the token popup flow used here.
#
# You can set the same value as GOOGLE_CLIENT_ID on the backend instead; the app
# will fetch it from GET /api/auth/google-client-id when this line is omitted.

VITE_GOOGLE_CLIENT_ID=

# Optional: full API base URL. Dev default is "/api" (Vite proxy).
# VITE_API_URL=http://localhost:8081/api
